<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>刷课 · AutomaticCB</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
        .log-area { font-family: 'JetBrains Mono', 'Fira Code', monospace; font-size: 12px; line-height: 1.6; }
        .log-area::-webkit-scrollbar { width: 6px; }
        .log-area::-webkit-scrollbar-thumb { background: #94a3b8; border-radius: 3px; }
        .dark .log-area::-webkit-scrollbar-thumb { background: #475569; }
        .progress-bar { transition: width .3s; height: 4px; background: #e5e7eb; border-radius: 4px; overflow: hidden; }
        .progress-bar .fill { height: 100%; background: linear-gradient(90deg, #6366f1, #06b6d4); border-radius: 4px; transition: width .3s; }
        .toast { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%); padding: 10px 20px; border-radius: 12px; font-size: 13px; z-index: 999; opacity: 0; transition: opacity .3s; pointer-events: none; }
        .toast.show { opacity: 1; }
        .toast.success { background: #059669; color: #fff; }
        .toast.error { background: rgba(220, 38, 38, 0.15); color: #dc2626; backdrop-filter: blur(4px); border: 1px solid rgba(220, 38, 38, 0.3); }
        .toast.info { background: #3b82f6; color: #fff; }
        .toast.warning { background: #d97706; color: #fff; }
        .switch { position: relative; display: inline-block; width: 36px; height: 20px; }
        .switch input { opacity: 0; width: 0; height: 0; }
        .switch .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background: #d1d5db; transition: .3s; border-radius: 20px; }
        .switch .slider:before { content: ''; position: absolute; height: 16px; width: 16px; left: 2px; bottom: 2px; background: #fff; transition: .3s; border-radius: 50%; }
        .switch input:checked + .slider { background: #6366f1; }
        .switch input:checked + .slider:before { transform: translateX(16px); }
        /* 彩色日志 */
        .log-line { display: flex; gap: 8px; padding: 1px 0; font-family: 'JetBrains Mono', 'Fira Code', monospace; font-size: 12px; line-height: 1.6; }
        .log-line .line-num { color: #9ca3af; min-width: 32px; text-align: right; user-select: none; font-size: 11px; flex-shrink: 0; }
        .log-line .line-time { color: #6b7280; min-width: 140px; flex-shrink: 0; font-size: 11px; }
        .log-line .line-level { min-width: 60px; font-weight: 600; flex-shrink: 0; }
        .log-line.level-INFO .line-level { color: #3b82f6; }
        .log-line.level-WARNING .line-level { color: #f59e0b; }
        .log-line.level-ERROR .line-level { color: #ef4444; }
        .log-line.level-SUCCESS .line-level { color: #10b981; }
        .log-line.level-PROGRESS { background: rgba(99,102,241,0.08); border-radius: 4px; }
        .log-line.level-PROGRESS .line-level { color: #6366f1; }
        .log-line.highlight { background: rgba(251,191,36,0.15); border-radius: 2px; }
        .dark .log-line.level-INFO .line-level { color: #60a5fa; }
        .dark .log-line.level-WARNING .line-level { color: #fbbf24; }
        .dark .log-line.level-ERROR .line-level { color: #f87171; }
        .dark .log-line.level-SUCCESS .line-level { color: #34d399; }
        .dark .log-line.level-PROGRESS { background: rgba(99,102,241,0.12); }
        .log-toolbar { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
        .log-toolbar input[type="text"] { font-size: 11px; padding: 4px 8px; border: 1px solid #d1d5db; border-radius: 6px; outline: none; background: #fff; width: 140px; }
        .dark .log-toolbar input[type="text"] { background: #1f2937; border-color: #374151; color: #e5e7eb; }
        .log-toolbar input[type="text"]:focus { border-color: #6366f1; }
        .log-toolbar button { font-size: 11px; padding: 4px 10px; border-radius: 6px; border: 1px solid #d1d5db; background: #fff; color: #374151; cursor: pointer; transition: all .15s; white-space: nowrap; }
        .dark .log-toolbar button { background: #1f2937; border-color: #374151; color: #d1d5db; }
        .log-toolbar button:hover { border-color: #6366f1; color: #6366f1; }
        .log-toolbar button.active { background: #6366f1; color: #fff; border-color: #6366f1; }
        .log-line.hidden-line { display: none; }
        .progress-text { font-size: 11px; color: #6366f1; font-weight: 500; padding: 4px 0; }
        .log-count { font-size: 11px; color: #9ca3af; font-weight: normal; }
    </style>
</head>
<body class="bg-gray-50 dark:bg-gray-900 text-gray-800 dark:text-gray-200 min-h-screen">
    <div id="toast" class="toast"></div>

    <!-- Header -->
    <header class="p-4 flex items-center justify-between border-b border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900/80 backdrop-blur-sm sticky top-0 z-50">
        <div class="flex items-center gap-3">
            <a href="index.html" class="p-2 rounded-full bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 shadow-sm hover:scale-105 transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            </a>
            <h1 class="text-sm font-bold tracking-wide">
                <span class="text-indigo-600 dark:text-indigo-400">刷课</span>
                <span class="text-gray-400 font-normal">· 超星学习通</span>
            </h1>
        </div>
        <div class="flex items-center gap-3">
            <button onclick="showLogin()" id="accountBtn" class="text-xs text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 px-3 py-1.5 rounded-full transition">加载中...</button>
            <button onclick="toggleDark()" class="p-2 rounded-full bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 shadow-sm hover:scale-105 transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path class="dark:hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
                    <path class="hidden dark:block" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707"/>
                </svg>
            </button>
        </div>
    </header>

    <!-- Login Modal -->
    <div id="loginOverlay" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[100] hidden flex items-center justify-center" onclick="if(event.target===this)hideLogin()">
        <div class="bg-white dark:bg-gray-800 rounded-2xl p-6 w-80 shadow-xl border border-gray-200 dark:border-gray-700" onclick="event.stopPropagation()">
            <h2 class="text-sm font-bold mb-4">登录超星学习通</h2>
            <div class="space-y-3">
                <div><label class="text-xs text-gray-500">手机号</label><input id="loginUser" class="w-full mt-1 px-3 py-2 text-sm border border-gray-200 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-900 outline-none focus:ring-2 focus:ring-indigo-500" placeholder="手机号"></div>
                <div><label class="text-xs text-gray-500">密码</label><input id="loginPass" type="password" class="w-full mt-1 px-3 py-2 text-sm border border-gray-200 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-900 outline-none focus:ring-2 focus:ring-indigo-500" placeholder="密码"></div>
                <button onclick="doLogin()" id="loginBtn" class="w-full py-2.5 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 rounded-full transition">登录 / 切换账号</button>
            </div>
            <button onclick="hideLogin()" class="w-full mt-2 py-2 text-xs text-gray-400 hover:text-gray-600 transition">取消</button>
        </div>
    </div>

    <!-- Main -->
    <main class="max-w-4xl mx-auto p-4 space-y-4">
        <!-- 学习统计 -->
        <section class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
            <div class="p-4 grid grid-cols-4 gap-4 text-center">
                <div>
                    <div class="text-lg font-bold text-indigo-600 dark:text-indigo-400" id="statTotal">0</div>
                    <div class="text-xs text-gray-400">总课程</div>
                </div>
                <div>
                    <div class="text-lg font-bold text-green-600 dark:text-green-400" id="statDone">0</div>
                    <div class="text-xs text-gray-400">已完成</div>
                </div>
                <div>
                    <div class="text-lg font-bold text-blue-600 dark:text-blue-400" id="statVideos">0</div>
                    <div class="text-xs text-gray-400">视频</div>
                </div>
                <div>
                    <div class="text-lg font-bold text-amber-600 dark:text-amber-400" id="statWorks">0</div>
                    <div class="text-xs text-gray-400">答题</div>
                </div>
            </div>
        </section>
        
        <!-- 课程列表 -->
        <section class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
            <div class="p-4 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between">
                <h2 class="text-sm font-bold flex items-center gap-2">
                    <svg class="w-4 h-4 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                    课程列表
                </h2>
                <button onclick="loadCourses()" class="p-2 text-gray-400 hover:text-blue-500 transition rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700">
                    <svg class="w-4 h-4 refresh-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                </button>
            </div>
            <div id="courseList" class="divide-y divide-gray-100 dark:divide-gray-700">
                <div class="p-6 text-center text-gray-400 text-sm">加载中...</div>
            </div>
            <div class="p-3 border-t border-gray-200 dark:border-gray-700 flex items-center justify-between text-xs text-gray-500">
                <span id="selectedCount">已选 0 门</span>
                <div class="flex gap-2">
                    <button onclick="selectAll()" class="hover:text-indigo-600 transition">全选</button>
                    <button onclick="deselectAll()" class="hover:text-indigo-600 transition">取消</button>
                </div>
            </div>
        </section>

        <!-- 控制 -->
        <section class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-4">
            <div class="flex items-center justify-between gap-4 flex-wrap">
                <span id="taskStatus" class="text-xs px-3 py-1.5 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-500">就绪</span>
                <div class="flex gap-2">
                    <button onclick="startTask()" id="startBtn" class="px-5 py-2 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 disabled:opacity-40 disabled:cursor-not-allowed rounded-full transition shadow-sm">开始刷课</button>
                    <button onclick="stopTask()" id="stopBtn" class="px-5 py-2 text-sm font-medium text-red-600 bg-red-50 dark:bg-red-900/20 dark:text-red-400 hover:bg-red-100 dark:hover:bg-red-900/30 disabled:opacity-40 disabled:cursor-not-allowed rounded-full transition border border-red-200 dark:border-red-800" disabled>停止</button>
                </div>
            </div>
        </section>

        <!-- 刷课设置 -->
        <details class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
            <summary class="p-4 text-sm font-bold cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700/50 transition flex items-center gap-2">
                <svg class="w-4 h-4 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                刷课设置
            </summary>
            <div class="p-4 border-t border-gray-200 dark:border-gray-700 space-y-3">
                <!-- 视频倍速 -->
                <div class="flex items-center justify-between">
                    <span class="text-xs text-gray-600 dark:text-gray-400">视频倍速</span>
                    <select id="brushSpeed" class="text-xs border border-gray-200 dark:border-gray-700 rounded-lg px-2 py-1.5 bg-white dark:bg-gray-900 outline-none">
                        <option value="0.5">0.5x</option>
                        <option value="1">1x</option>
                        <option value="1.25">1.25x</option>
                        <option value="1.5">1.5x</option>
                        <option value="1.75">1.75x</option>
                        <option value="2" selected>2x</option>
                    </select>
                </div>
                <!-- 自动播放下一章 -->
                <div class="flex items-center justify-between">
                    <span class="text-xs text-gray-600 dark:text-gray-400">自动播放下一章</span>
                    <label class="switch"><input type="checkbox" id="brushAutoNext" checked><span class="slider"></span></label>
                </div>
                <!-- 刷课模式 -->
                <div class="flex items-center justify-between">
                    <span class="text-xs text-gray-600 dark:text-gray-400">刷课模式</span>
                    <select id="brushMode" class="text-xs border border-gray-200 dark:border-gray-700 rounded-lg px-2 py-1.5 bg-white dark:bg-gray-900 outline-none">
                        <option value="all">视频+答题</option>
                        <option value="video">仅视频</option>
                        <option value="work">仅答题</option>
                    </select>
                </div>
                <!-- 章节顺序 -->
                <div class="flex items-center justify-between">
                    <span class="text-xs text-gray-600 dark:text-gray-400">章节顺序</span>
                    <select id="chapterOrder" class="text-xs border border-gray-200 dark:border-gray-700 rounded-lg px-2 py-1.5 bg-white dark:bg-gray-900 outline-none">
                        <option value="sequential">顺序</option>
                        <option value="random">随机</option>
                    </select>
                </div>
                <!-- API 同步 -->
                <div class="border-t border-gray-200 dark:border-gray-700 pt-3">
                    <button onclick="syncBrushConfig()" class="w-full py-2 text-xs font-medium text-indigo-600 bg-indigo-50 dark:bg-indigo-900/20 rounded-lg hover:bg-indigo-100 dark:hover:bg-indigo-900/30 transition">从聊天项目同步 API</button>
                    <div id="syncStatus" class="mt-1 text-xs text-gray-400 text-center">未同步</div>
                </div>
                <!-- 保存 -->
                <button onclick="saveBrushConfig()" class="w-full py-2 text-xs font-medium text-white bg-indigo-600 hover:bg-indigo-700 rounded-lg transition">保存刷课设置</button>
            </div>
        </details>

        <!-- 题库设置 -->
        <details class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
            <summary class="p-4 text-sm font-bold cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700/50 transition flex items-center gap-2">
                <svg class="w-4 h-4 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                题库设置
            </summary>
            <div class="p-4 border-t border-gray-200 dark:border-gray-700 space-y-3">
                <div class="flex items-center justify-between">
                    <span class="text-xs text-gray-600 dark:text-gray-400">题库提供商</span>
                    <select id="tikuProvider" class="text-xs border border-gray-200 dark:border-gray-700 rounded-lg px-2 py-1.5 bg-white dark:bg-gray-900 outline-none">
                        <option value="TikuYanxi,TikuAI">言溪+AI链式 (推荐)</option>
                        <option value="TikuYanxi">仅言溪题库</option>
                        <option value="TikuAI">仅AI答题</option>
                    </select>
                </div>
                <div id="tikuTokensGroup">
                    <label class="text-xs text-gray-500">API Token（多个用逗号隔开）</label>
                    <input id="tikuTokens" class="w-full mt-1 px-3 py-2 text-xs border border-gray-200 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-900 outline-none" placeholder="5cb32d2a461d4aec928823ae58fa33be">
                </div>
                <div id="tikuAIGroup" class="hidden space-y-3">
                    <div>
                        <label class="text-xs text-gray-500">AI接口地址</label>
                        <input id="tikuAIUrl" class="w-full mt-1 px-3 py-2 text-xs border border-gray-200 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-900 outline-none" placeholder="https://api.deepseek.com">
                    </div>
                    <div>
                        <label class="text-xs text-gray-500">AI模型</label>
                        <select id="tikuAIModel" class="w-full mt-1 px-3 py-2 text-xs border border-gray-200 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-900 outline-none">
                            <option value="deepseek-chat">deepseek-chat</option>
                        </select>
                        <button onclick="syncModels()" class="mt-1 text-xs text-indigo-600 hover:text-indigo-500 transition">↻ 刷新模型列表</button>
                    </div>
                    <div>
                        <label class="text-xs text-gray-500">API Key</label>
                        <div class="flex gap-2">
                            <input id="tikuAIKey" type="password" class="flex-1 mt-1 px-3 py-2 text-xs border border-gray-200 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-900 outline-none" placeholder="sk-xxx">
                            <button onclick="syncAIKey()" class="mt-1 px-2 py-1 text-xs text-indigo-600 bg-indigo-50 dark:bg-indigo-900/20 rounded-lg hover:bg-indigo-100 dark:hover:bg-indigo-900/30 transition whitespace-nowrap" title="从聊天设置同步">从聊天同步</button>
                        </div>
                    </div>
                </div>
                <div class="flex items-center justify-between">
                    <span class="text-xs text-gray-600 dark:text-gray-400">自动提交答题</span>
                    <label class="switch"><input type="checkbox" id="tikuSubmit"><span class="slider"></span></label>
                </div>
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="text-xs text-gray-500">正确选项</label>
                        <input id="tikuTrue" class="w-full mt-1 px-2 py-1.5 text-xs border border-gray-200 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-900 outline-none" value="正确,对,√,是">
                    </div>
                    <div>
                        <label class="text-xs text-gray-500">错误选项</label>
                        <input id="tikuFalse" class="w-full mt-1 px-2 py-1.5 text-xs border border-gray-200 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-900 outline-none" value="错误,错,×,否,不对,不正确">
                    </div>
                </div>
                <button onclick="saveTiku()" class="w-full py-2 text-xs font-medium text-white bg-indigo-600 hover:bg-indigo-700 rounded-lg transition">保存题库设置</button>
            </div>
        </details>

        <!-- 日志 -->
        <section class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
            <div class="p-4 border-b border-gray-200 dark:border-gray-700">
                <div class="flex items-center justify-between mb-2">
                    <h2 class="text-sm font-bold flex items-center gap-2">
                        运行日志
                        <span id="logCount" class="log-count">0 行</span>
                    </h2>
                    <div class="flex items-center gap-3">
                        <span class="text-xs text-gray-400">自动跟踪</span>
                        <label class="switch"><input type="checkbox" id="autoFollow" checked><span class="slider"></span></label>
                        <button onclick="clearLog()" class="text-xs text-gray-400 hover:text-red-500 transition px-2 py-1 rounded hover:bg-gray-100 dark:hover:bg-gray-700">清空</button>
                    </div>
                </div>
                <!-- 进度条 -->
                <div id="progressContainer" class="hidden mb-2">
                    <div class="progress-text" id="progressText"></div>
                    <div class="progress-bar"><div class="fill" id="progressFill" style="width:0%"></div></div>
                </div>
                <!-- 工具栏 -->
                <div class="log-toolbar">
                    <input type="text" id="logSearch" placeholder="🔍 搜索日志..." oninput="filterLogs()">
                    <button id="errorFilterBtn" onclick="toggleErrorFilter()">仅显示错误</button>
                    <button onclick="copyLog()">📋 复制</button>
                    <button onclick="exportLog()">⬇ 导出</button>
                </div>
            </div>
            <div id="logArea" class="log-area p-4 h-96 overflow-y-auto"></div>
        </section>
    </main>

    <script>
        let pollTimer = null;
        let logLinesData = [];
        let errorFilterActive = false;
        let searchQuery = '';
        function $(id) { return document.getElementById(id); }
        
        // 解密函数（与聊天项目一致，apiKey在localStorage里是加密存储的）
        var _encKey = 'naujtrats-secret';
        function _decrypt(encoded) {
            if (!encoded) return '';
            try {
                var bin = atob(encoded), bytes = new Uint8Array(bin.length);
                for (var i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
                var key = new TextEncoder().encode(_encKey);
                var res = new Uint8Array(bytes.length);
                for (var i = 0; i < bytes.length; i++) res[i] = bytes[i] ^ key[i % key.length];
                return new TextDecoder().decode(res);
            } catch(e) { return encoded; }
        }
        function _getApiKey() { return _decrypt(localStorage.getItem('apiKey')); }
        function _getBaseUrl() { return localStorage.getItem('baseUrl') || 'https://api.deepseek.com'; }
        
        // Dark mode
        function toggleDark() {
            document.documentElement.classList.toggle('dark');
            localStorage.setItem('chaoxingDark', document.documentElement.classList.contains('dark'));
        }
        if (localStorage.getItem('chaoxingDark') === 'true') document.documentElement.classList.add('dark');

        // Toast
        let toastTimer;
        function showToast(msg, type='info') {
            const t = $('toast');
            t.textContent = msg; t.className = 'toast show ' + type;
            clearTimeout(toastTimer); toastTimer = setTimeout(() => t.classList.remove('show'), 3000);
        }

        // ====== 日志系统 ======
        function parseLogLine(line) {
            var match = line.match(/^(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}) - (\w+) - (.+)$/);
            if (match) {
                return { time: match[1], level: match[2], message: match[3], raw: line };
            }
            // 进度行
            if (line.indexOf('当前任务:') === 0) {
                return { time: '', level: 'PROGRESS', message: line, raw: line };
            }
            // 其他行（无级别标记）
            return { time: '', level: 'NONE', message: line, raw: line };
        }

        function getLevelForClass(level) {
            var upper = (level || '').toUpperCase();
            if (upper === 'INFO') return 'INFO';
            if (upper === 'WARNING' || upper === 'WARN') return 'WARNING';
            if (upper === 'ERROR' || upper.indexOf('FAIL') !== -1 || upper.indexOf('ERR') !== -1) return 'ERROR';
            if (upper === 'SUCCESS' || upper.indexOf('完成') !== -1 || upper.indexOf('SUCCESS') !== -1) return 'SUCCESS';
            if (upper === 'PROGRESS') return 'PROGRESS';
            return 'INFO';
        }

        function escapeHtml(text) {
            var div = document.createElement('div');
            div.appendChild(document.createTextNode(text));
            return div.innerHTML;
        }

        function renderLog(logText) {
            var el = $('logArea');
            if (!logText) {
                el.innerHTML = '';
                logLinesData = [];
                updateLogCount();
                updateProgress('');
                return;
            }
            var rawLines = logText.split('\n');
            var lines = [];
            for (var i = 0; i < rawLines.length; i++) {
                var trimmed = rawLines[i].trim();
                if (!trimmed) continue;
                lines.push(trimmed);
            }
            
            // 安全阀：最多 500 行
            if (lines.length > 500) {
                lines = lines.slice(lines.length - 500);
            }

            logLinesData = [];
            var html = '';
            var lastProgress = '';
            for (var i = 0; i < lines.length; i++) {
                var parsed = parseLogLine(lines[i]);
                var lineNum = i + 1;
                var levelClass = getLevelForClass(parsed.level);
                var lineHtml = '<div class="log-line level-' + levelClass + '" data-line="' + lineNum + '">';
                lineHtml += '<span class="line-num">' + lineNum + '</span>';
                if (parsed.time) {
                    lineHtml += '<span class="line-time">' + escapeHtml(parsed.time) + '</span>';
                    lineHtml += '<span class="line-level">' + escapeHtml(parsed.level) + '</span>';
                    lineHtml += '<span class="line-msg">' + escapeHtml(parsed.message) + '</span>';
                } else if (levelClass === 'PROGRESS') {
                    lineHtml += '<span class="line-time"></span>';
                    lineHtml += '<span class="line-level">⚡进度</span>';
                    lineHtml += '<span class="line-msg">' + escapeHtml(parsed.message) + '</span>';
                    lastProgress = parsed.message;
                } else {
                    lineHtml += '<span class="line-time"></span>';
                    lineHtml += '<span class="line-level"></span>';
                    lineHtml += '<span class="line-msg">' + escapeHtml(parsed.message) + '</span>';
                }
                lineHtml += '</div>';
                logLinesData.push({ html: lineHtml, level: levelClass, message: parsed.message, raw: parsed.raw });
                html += lineHtml;
            }
            el.innerHTML = html;
            updateLogCount();
            updateProgress(lastProgress);
            applyFilters();
        }

        function updateLogCount() {
            var visible = 0;
            if (logLinesData.length && errorFilterActive) {
                // Count visible lines
                var els = $('logArea').querySelectorAll('.log-line:not(.hidden-line)');
                visible = els.length;
            } else {
                visible = logLinesData.length;
            }
            $('logCount').textContent = logLinesData.length + ' 行' + (errorFilterActive ? ' (显示 ' + visible + ')' : '');
        }

        function updateProgress(progressText) {
            var container = $('progressContainer');
            var textEl = $('progressText');
            if (progressText) {
                container.classList.remove('hidden');
                textEl.textContent = progressText;
                // 尝试解析进度百分比
                var pctMatch = progressText.match(/(\d+)\/(\d+)/);
                if (pctMatch) {
                    var pct = Math.round(parseInt(pctMatch[1]) / parseInt(pctMatch[2]) * 100);
                    $('progressFill').style.width = pct + '%';
                } else {
                    $('progressFill').style.width = '50%';
                }
            } else {
                container.classList.add('hidden');
                textEl.textContent = '';
                $('progressFill').style.width = '0%';
            }
        }

        function applyFilters() {
            var searchVal = searchQuery.toLowerCase().trim();
            var lines = $('logArea').querySelectorAll('.log-line');
            for (var i = 0; i < lines.length; i++) {
                var line = lines[i];
                var data = logLinesData[i];
                if (!data) continue;
                var hide = false;
                // 错误过滤器
                if (errorFilterActive && data.level !== 'ERROR') {
                    hide = true;
                }
                // 搜索高亮
                line.classList.remove('highlight');
                if (searchVal && !hide) {
                    var msg = data.message.toLowerCase();
                    if (msg.indexOf(searchVal) !== -1) {
                        line.classList.add('highlight');
                    } else {
                        hide = true;
                    }
                }
                line.classList.toggle('hidden-line', hide);
            }
            updateLogCount();
            scrollToBottomIfFollow();
        }

        function filterLogs() {
            searchQuery = $('logSearch').value;
            applyFilters();
        }

        function toggleErrorFilter() {
            errorFilterActive = !errorFilterActive;
            $('errorFilterBtn').classList.toggle('active', errorFilterActive);
            applyFilters();
        }

        function copyLog() {
            var text = logLinesData.map(function(d) { return d.raw; }).join('\n');
            if (!text) { showToast('日志为空', 'warning'); return; }
            navigator.clipboard.writeText(text).then(function() {
                showToast('已复制 ' + logLinesData.length + ' 行日志', 'success');
            }).catch(function() {
                showToast('复制失败', 'error');
            });
        }

        function exportLog() {
            var text = logLinesData.map(function(d) { return d.raw; }).join('\n');
            if (!text) { showToast('日志为空', 'warning'); return; }
            var blob = new Blob([text], { type: 'text/plain;charset=utf-8' });
            var url = URL.createObjectURL(blob);
            var a = document.createElement('a');
            a.href = url;
            a.download = 'chaoxing_log_' + new Date().toISOString().slice(0,19).replace(/[:-]/g,'') + '.txt';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
            showToast('已导出 ' + logLinesData.length + ' 行日志', 'success');
        }

        function scrollToBottomIfFollow() {
            var el = $('logArea');
            if ($('autoFollow').checked) {
                el.scrollTop = el.scrollHeight;
            }
        }

        // ====== Account ======
        async function loadAccount() {
            try {
                const r = await fetch('chaoxing_api.php?action=account');
                const d = await r.json();
                $('accountBtn').textContent = d.username ? d.masked : '点击登录';
            } catch(e) { $('accountBtn').textContent = '点击登录'; }
        }

        function showLogin() {
            $('loginOverlay').classList.remove('hidden');
            $('loginUser').focus();
        }
        function hideLogin() { $('loginOverlay').classList.add('hidden'); }

        async function doLogin() {
            const user = $('loginUser').value.trim();
            const pass = $('loginPass').value;
            if (!user || !pass) { showToast('请输入账号和密码', 'error'); return; }
            const btn = $('loginBtn'); btn.disabled = true; btn.textContent = '验证中...';
            try {
                const r = await fetch('chaoxing_api.php?action=login&username='+encodeURIComponent(user)+'&password='+encodeURIComponent(pass));
                const d = await r.json();
                if (d.success) {
                    showToast('登录成功: ' + user, 'success');
                    hideLogin();
                    loadAccount();
                    loadCourses();
                } else {
                    showToast(d.error || '登录失败', 'error');
                }
            } catch(e) { showToast('网络错误', 'error'); }
            finally { btn.disabled = false; btn.textContent = '登录 / 切换账号'; }
        }

        // Enter key for login
        $('loginPass').addEventListener('keydown', e => { if (e.key === 'Enter') doLogin(); });

        // Courses
        async function loadCourses() {
            const list = $('courseList');
            list.innerHTML = '<div class="p-6 text-center text-gray-400 text-sm">加载中...</div>';
            try {
                const r = await fetch('chaoxing_api.php?action=courses');
                const d = await r.json();
                if (d.error) { list.innerHTML = '<div class="p-6 text-center text-red-400 text-sm">'+d.error+'</div>'; return; }
                const courses = d.courses || [];
                if (!courses.length) { list.innerHTML = '<div class="p-6 text-center text-gray-400 text-sm">暂无课程</div>'; return; }
                list.innerHTML = courses.map(c => {
                    var badge = '';
                    var disabled = c.disabled ? 'disabled' : '';
                    var checked = c.checked ? 'checked' : '';
                    var statusClass = '';
                    if (c.db_status === 'completed') {
                        badge = '<span class="text-xs text-green-600 dark:text-green-400 bg-green-100 dark:bg-green-900/30 px-2 py-0.5 rounded-full">已完成 ✓</span>';
                        statusClass = 'opacity-70';
                    } else if (c.db_status === 'in_progress') {
                        badge = '<span class="text-xs text-blue-600 dark:text-blue-400 bg-blue-100 dark:bg-blue-900/30 px-2 py-0.5 rounded-full">刷课中</span>';
                        statusClass = 'opacity-70';
                    } else if (c.db_status === 'not_started' && c.disabled) {
                        // 在配置列表但未开始
                        badge = '<span class="text-xs text-amber-600 dark:text-amber-400 bg-amber-100 dark:bg-amber-900/30 px-2 py-0.5 rounded-full">已选</span>';
                        statusClass = 'opacity-70';
                    }
                    var clickHandler = disabled ? '' : ' onclick="toggleCb(this)"';
                    var cursorClass = disabled ? '' : ' cursor-pointer';
                    return '<div class="flex items-center gap-3 px-4 py-3 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition' + cursorClass + ' ' + statusClass + '"' + clickHandler + '>' +
                        '<input type="checkbox" class="course-cb w-4 h-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" value="' + c.courseId + '" ' + checked + ' ' + disabled + '>' +
                        '<div class="flex-1 min-w-0">' +
                            '<div class="text-sm font-medium truncate flex items-center gap-2">' + c.title + ' ' + badge + '</div>' +
                            '<div class="text-xs text-gray-400">' + (c.teacher || '') + '</div>' +
                        '</div>' +
                        '<span class="text-xs text-gray-400 bg-gray-100 dark:bg-gray-700 px-2 py-1 rounded-full">' + c.courseId + '</span>' +
                    '</div>';
                }).join('');
            } catch(e) { list.innerHTML = '<div class="p-6 text-center text-red-400 text-sm">加载失败</div>'; }
            loadStats();
            updateCount();
        }

        function toggleCb(el) {
            const cb = el.querySelector('.course-cb');
            if (cb.disabled) return;
            cb.checked = !cb.checked;
            el.classList.toggle('bg-indigo-50', cb.checked);
            el.classList.toggle('dark:bg-indigo-900/20', cb.checked);
            updateCount();
        }
        function updateCount() {
            $('selectedCount').textContent = '已选 ' + document.querySelectorAll('.course-cb:checked').length + ' 门';
        }
        function selectAll() { document.querySelectorAll('.course-cb:not(:disabled)').forEach(c => { c.checked = true; c.closest('div[onclick]')?.classList.add('bg-indigo-50','dark:bg-indigo-900/20'); }); updateCount(); }
        function deselectAll() { document.querySelectorAll('.course-cb').forEach(c => { c.checked = false; c.closest('div[onclick]')?.classList.remove('bg-indigo-50','dark:bg-indigo-900/20'); }); updateCount(); }

        // Task
        async function startTask() {
            const checked = document.querySelectorAll('.course-cb:checked');
            if (!checked.length) { showToast('请先选择课程', 'error'); return; }
            const ids = Array.from(checked).map(c => c.value).join(',');
            try {
                const r = await fetch('chaoxing_api.php?action=start&ids='+ids);
                const d = await r.json();
                if (d.error) { showToast(d.error, 'error'); return; }
                showToast('任务已启动', 'success');
                $('startBtn').disabled = true; $('stopBtn').disabled = false;
                setStatus('运行中...', 'text-green-600 bg-green-100 dark:bg-green-900/30');
                clearLog();
                startPoll();
            } catch(e) { showToast('启动失败', 'error'); }
        }

        async function stopTask() {
            await fetch('chaoxing_api.php?action=stop');
            stopPoll();
            $('startBtn').disabled = false; $('stopBtn').disabled = true;
            setStatus('已停止', 'text-red-500 bg-red-100 dark:bg-red-900/30');
            showToast('已停止', 'info');
        }

        function setStatus(text, cls) {
            const el = $('taskStatus');
            el.textContent = text; el.className = 'text-xs px-3 py-1.5 rounded-full ' + cls;
        }

        // Polling
        function startPoll() { pollTimer = setInterval(pollStatus, 2000); }
        function stopPoll() { if (pollTimer) { clearInterval(pollTimer); pollTimer = null; } }

        async function pollStatus() {
            try {
                const r = await fetch('chaoxing_api.php?action=status');
                const d = await r.json();
                if (d.log) {
                    renderLog(d.log);
                    scrollToBottomIfFollow();
                }
                if (!d.running) {
                    stopPoll();
                    $('startBtn').disabled = false; $('stopBtn').disabled = true;
                    setStatus('已完成', 'text-blue-600 bg-blue-100 dark:bg-blue-900/30');
                    showToast('刷课任务完成', 'success');
                    loadCourses();
                }
                loadStats();
            } catch(e) {}
        }

        // 页面加载时检查是否有运行中的任务
        async function checkRunning() {
            try {
                const r = await fetch('chaoxing_api.php?action=status');
                const d = await r.json();
                if (d.running) {
                    $('startBtn').disabled = true; $('stopBtn').disabled = false;
                    setStatus('运行中...', 'text-green-600 bg-green-100 dark:bg-green-900/30');
                    if (d.log) renderLog(d.log);
                    startPoll();
                }
                loadStats();
            } catch(e) {}
        }

        function clearLog() {
            $('logArea').innerHTML = '';
            logLinesData = [];
            errorFilterActive = false;
            $('errorFilterBtn').classList.remove('active');
            searchQuery = '';
            $('logSearch').value = '';
            updateLogCount();
            updateProgress('');
        }

        // Tiku
        function toggleTikuProvider() {
            var val = $('tikuProvider').value;
            var hasAI = val.indexOf('TikuAI') !== -1;
            var hasYanxi = val.indexOf('TikuYanxi') !== -1;
            $('tikuTokensGroup').classList.toggle('hidden', !hasYanxi);
            $('tikuAIGroup').classList.toggle('hidden', !hasAI);
        }
        $('tikuProvider').addEventListener('change', toggleTikuProvider);

        async function syncModels() {
            var sel = $('tikuAIModel');
            var cached = JSON.parse(localStorage.getItem('autoDetectedTextModels') || '[]');
            if (cached.length > 0) {
                sel.innerHTML = cached.map(function(m) {
                    return '<option value="' + m + '">' + m + '</option>';
                }).join('');
            }
            var key = _getApiKey();
            var baseUrl = _getBaseUrl();
            if (!key || !baseUrl) { showToast('已加载缓存列表（共' + (cached.length || 0) + '个）', 'info'); return; }
            sel.innerHTML = sel.innerHTML || '<option>加载中...</option>';
            try {
                var r = await fetch(baseUrl.replace(/\/+$/, '') + '/models', {
                    headers: { 'Authorization': 'Bearer ' + key }
                });
                if (!r.ok) throw new Error('HTTP ' + r.status);
                var data = await r.json();
                var models = data.data || [];
                if (models.length) {
                    sel.innerHTML = models.map(function(m) {
                        return '<option value="' + m.id + '">' + m.id + '</option>';
                    }).join('');
                    showToast('已获取 ' + sel.options.length + ' 个模型', 'success');
                }
            } catch(e) {
                if (cached.length > 0) showToast('已使用缓存模型列表', 'info');
                else sel.innerHTML = '<option value="deepseek-chat">deepseek-chat</option>';
            }
        }

        async function syncAIKey() {
            var key = _getApiKey();
            var url = _getBaseUrl();
            if (key) {
                $('tikuAIKey').value = key;
                $('tikuAIUrl').value = url;
                syncModels();
                showToast('已同步API Key和模型列表', 'success');
            } else {
                showToast('未找到聊天API Key，请先在设置中配置', 'error');
            }
        }

        async function loadTiku() {
            try {
                const r = await fetch('chaoxing_api.php?action=tiku_config');
                const d = await r.json();
                $('tikuProvider').value = d.provider || 'TikuYanxi';
                $('tikuTokens').value = d.tokens || '';
                $('tikuSubmit').checked = d.submit !== false;
                $('tikuTrue').value = d.true_list || '正确,对,√,是';
                $('tikuFalse').value = d.false_list || '错误,错,×,否,不对,不正确';
                $('tikuAIUrl').value = d.ai_base_url || _getBaseUrl();
                $('tikuAIKey').value = d.ai_key || _getApiKey() || '';
                // 从聊天系统拉取模型列表
                try {
                    var models = JSON.parse(localStorage.getItem('autoDetectedTextModels') || '[]');
                    var sel = $('tikuAIModel');
                    if (models.length > 0) {
                        sel.innerHTML = models.map(function(m) {
                            return '<option value="' + m + '">' + m + '</option>';
                        }).join('');
                    }
                } catch(e) {}
                $('tikuAIModel').value = d.ai_model || localStorage.getItem('model') || 'deepseek-chat';
                toggleTikuProvider();
            } catch(e) {}
        }
        
        async function saveTiku() {
            const params = new URLSearchParams({
                provider: $('tikuProvider').value,
                tokens: $('tikuTokens').value,
                submit: $('tikuSubmit').checked ? 'true' : 'false',
                true_list: $('tikuTrue').value,
                false_list: $('tikuFalse').value
            });
            // AI 额外参数
            if ($('tikuProvider').value.indexOf('TikuAI') !== -1) {
                params.append('ai_base_url', $('tikuAIUrl').value);
                params.append('ai_model', $('tikuAIModel').value);
                params.append('ai_key', $('tikuAIKey').value);
            }
            try {
                const r = await fetch('chaoxing_api.php?action=save_tiku&' + params);
                const d = await r.json();
                if (d.success) showToast('题库设置已保存', 'success');
                else showToast('保存失败', 'error');
            } catch(e) { showToast('保存失败', 'error'); }
        }

        // 刷课设置
        async function loadBrushConfig() {
            try {
                const r = await fetch('chaoxing_api.php?action=config');
                const d = await r.json();
                $('brushSpeed').value = d.speed || '2';
                $('brushAutoNext').checked = d.auto_next !== false;
                $('brushMode').value = d.brush_mode || 'all';
                $('chapterOrder').value = d.chapter_order || 'sequential';
                var syncStatus = $('syncStatus');
                var key = _getApiKey();
                if (key) {
                    syncStatus.textContent = '已同步: ' + key.substring(0, 8) + '...';
                    syncStatus.className = 'mt-1 text-xs text-green-500 text-center';
                } else {
                    syncStatus.textContent = '未同步（点击按钮从聊天项目同步）';
                    syncStatus.className = 'mt-1 text-xs text-gray-400 text-center';
                }
            } catch(e) {}
        }

        async function saveBrushConfig() {
            const params = new URLSearchParams({
                speed: $('brushSpeed').value,
                auto_next: $('brushAutoNext').checked ? 'true' : 'false',
                brush_mode: $('brushMode').value,
                chapter_order: $('chapterOrder').value
            });
            try {
                const r = await fetch('chaoxing_api.php?action=save_config&' + params);
                const d = await r.json();
                if (d.success) {
                    showToast('刷课设置已保存', 'success');
                } else {
                    showToast('保存失败', 'error');
                }
            } catch(e) { showToast('保存失败', 'error'); }
        }

        function syncBrushConfig() {
            var key = _getApiKey();
            var url = _getBaseUrl();
            if (key) {
                var syncStatus = $('syncStatus');
                syncStatus.textContent = '已同步: ' + key.substring(0, 8) + '...';
                syncStatus.className = 'mt-1 text-xs text-green-500 text-center';
                showToast('已同步聊天项目 API 信息', 'success');
            } else {
                showToast('未找到聊天API Key，请先在设置中配置', 'error');
            }
        }

        // Stats
        async function loadStats() {
            try {
                const r = await fetch('chaoxing_api.php?action=stats');
                const d = await r.json();
                $('statTotal').textContent = d.total_courses || 0;
                $('statDone').textContent = d.completed || 0;
                $('statVideos').textContent = d.videos_done || 0;
                $('statWorks').textContent = d.works_done || 0;
            } catch(e) {}
        }

        // Init
        // 自动跟踪状态
        var followPref = localStorage.getItem('chaoxingLogFollow');
        if (followPref === 'false') $('autoFollow').checked = false;
        $('autoFollow').addEventListener('change', function() {
            localStorage.setItem('chaoxingLogFollow', this.checked);
            if (this.checked) scrollToBottomIfFollow();
        });

        loadAccount();
        loadTiku();
        loadBrushConfig();
        loadCourses();
        checkRunning();
        loadStats();
    </script>
</body>
